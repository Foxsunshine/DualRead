# Build-time configuration for the Chrome extension.
#
# Copy this file to one of:
#   .env.production          (default for `npm run build`)
#   .env.development         (for `npm run build -- --mode development`
#                             or `npm run dev`)
#   .env.local               (per-machine overrides; loaded last,
#                             wins over both of the above)
#
# All three are gitignored via `.env*` in .gitignore. NEVER commit
# real values — the Railway URL and OAuth client_id below would land
# in the public repo otherwise.

# ───── Backend API base URL ─────
# The extension's host_permissions and src/shared/config.ts both
# pull from this. Use the localhost target for dev (uvicorn run from
# the DualRead-backend repo per docs/runbooks/dev-login.md). Use the
# Railway-issued domain for prod (from
# DualRead-backend/docs/runbooks/deploy.md §6 "Generate Domain").
#
# Examples (do not commit either of these):
#   VITE_API_BASE_URL=http://localhost:8000
#   VITE_API_BASE_URL=https://YOUR-RAILWAY-SUBDOMAIN.up.railway.app
VITE_API_BASE_URL=

# ───── Google OAuth Chrome Extension client_id ─────
# Tied to the unpacked-extension installation ID, obtained from
# https://console.cloud.google.com/apis/credentials per
# DualRead-backend/docs/runbooks/dev-login.md §1. Looks like
# 1234567890-abc.apps.googleusercontent.com.
VITE_OAUTH_CLIENT_ID=
