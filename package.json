{
  "name": "dualread",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "DualRead — Chinese speakers learning English: save unknown words while browsing, highlight them everywhere they appear.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.5"
  }
}
